# ──────────────────────────────────────────────
# Clara AI Pipeline – Environment Variables
# ──────────────────────────────────────────────
# Copy this file to  .env  and fill in values.

# ── LLM Provider (Groq free tier – https://console.groq.com) ──
GROQ_API_KEY=your_groq_api_key_here

# ── Retell (optional – free-tier key if available) ──
RETELL_API_KEY=

# ── Task Tracker (optional) ──
# If you want GitHub Issues as task tracker, provide a PAT with repo scope
GITHUB_TOKEN=
GITHUB_REPO=your_username/clara-ai-pipeline

# ── Misc ──
OUTPUT_DIR=outputs
DATASET_DIR=dataset
LOG_LEVEL=INFO
